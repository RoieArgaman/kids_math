# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and must never be committed.

# Firebase service account credentials (paste the full JSON on a single line)
FIRESTORE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters.
JWT_SECRET=replace_with_at_least_32_random_chars

# --- BUILD-TIME ONLY (never used by the running app / CI) ---
# Google Cloud TTS service account JSON, used solely by scripts/generate-audio.mjs to
# pre-generate audio files. The app plays committed files and never needs this key.
# You may reuse FIRESTORE_CREDENTIALS_JSON if that account has the TTS API enabled.
# GCP_TTS_CREDENTIALS_JSON={"type":"service_account", ...}

# Anthropic API key, used solely by scripts/author-content.mjs and
# scripts/audit-content-accuracy.mjs (authoring-time). Never used by the running app.
# ANTHROPIC_API_KEY=sk-ant-...
