{
  "name": "kids_math",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:testids": "node scripts/check-testids.mjs",
    "check:cards": "node scripts/check-cards.mjs",
    "codemod:add-testids": "node scripts/add-missing-testids.mjs",
    "codemod:dedupe-testids": "node scripts/dedupe-testids.mjs",
    "test:qa": "npm run lint && npm run test:unit && npm run build && npm run test:e2e",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "create-user": "node --env-file=.env.local scripts/create-user.mjs",
    "deploy:firebase": "./deploy.sh --project kids-learing-hub",
    "deploy:firebase:quick": "./deploy.sh --project kids-learing-hub --skip-tests",
    "deploy:firebase:upload-only": "./deploy.sh --project kids-learing-hub --skip-tests --skip-build"
  },
  "dependencies": {
    "@types/node": "^26",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "bcryptjs": "^3.0.3",
    "firebase-admin": "^14.2.0",
    "jose": "^6.2.3",
    "next": "14.2.28",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8",
    "eslint-config-next": "14.2.28",
    "jsdom": "^25.0.1",
    "ts-morph": "^28.0.0",
    "vitest": "^2.1.8"
  }
}
